{
  "name": "bamboost",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "quarto-build": "mkdir -p .docs/ && rm -r .docs/** && bash content/_scripts/copyMdx.sh content/docs .docs/docs && quarto render content --execute",
    "build": "next build",
    "dev": "concurrently \"node content/_scripts/watchMdx.js\" \"quarto preview content\"",
    "start": "next start",
    "postinstall": "fumadocs-mdx",
    "sync-oramacloud": "node --localstorage-file localstorage.json --env-file=.env scripts/update-orama.ts",
    "create-source": "tsx fumapy/create-source.ts"
  },
  "dependencies": {
    "@orama/core": "^1.2.19",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "fumadocs-core": "16.6.5",
    "fumadocs-mdx": "14.2.8",
    "fumadocs-python-autodoc": "^0.0.5",
    "fumadocs-ui": "16.6.5",
    "geist": "^1.7.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@oramacloud/client": "^2.1.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "clsx": "^2.1.1",
    "fs-extra": "^11.3.3",
    "katex": "^0.16.33",
    "lucide-react": "^0.575.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "zod": "^4.3.6"
  }
}
